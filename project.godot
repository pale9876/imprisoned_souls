; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addons]

ss2d/version="3.3.1"
resources_spreadsheet_view/array_color_tint=100.0
resources_spreadsheet_view/color_rows=true
resources_spreadsheet_view/array_min_width=128.0
resources_spreadsheet_view/resource_preview_size=32.0
resources_spreadsheet_view/clip_headers=false
resources_spreadsheet_view/dupe_arrays=true
resources_spreadsheet_view/context_menu_on_leftclick=false
resources_spreadsheet_view/fold_docks=true
resources_spreadsheet_view/resource_cell_label_mode=1
resources_spreadsheet_view/freeze_first_column=true

[application]

config/name="Imprisoned Souls"
config/description="프레임워크 이름: 구속된 영혼들

설명: 이 프레임워크는 다음과 같은 목적으로 제작되고 있습니다.
- 2D 횡스크롤 액션 제작과 개발 및 사후지원에 최적화된 환경
- 안정적인 성능과 중하급의 PC 및 다양한 OS에서의 지원

Author: Pale9876 (Github, Korean)

장르: 코스믹 호러
등급: 자율적, {만 19세 이상, 한국}, {18 +, 일본, 미국}
태그: 액션, 전략, 실시간 경영, 폭력성, 신체훼손"
run/main_scene="uid://2cbinw3drmxd"
config/features=PackedStringArray("4.7", "GL Compatibility")
run/max_fps=144
config/icon="res://icon.svg"

[autoload]

Global="*uid://d1fcpj0k6kkip"
DialogueManager="*uid://c3rodes2l3gxb"
InputHandler="*uid://e3v8nla7qwf3"
ImageSelector="*uid://bkb1epbrwsfbn"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/energy_saving/keep_screen_on=false
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="ProjectR"

[editor]

script/templates_search_path="res://template/script"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

[global]

currency_resource_path="res://"
draw_hurtbox=true

